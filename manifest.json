{
  "manifest_version": 3,
  "name": "Claude Chat Navigator",
  "version": "1.0.0",
  "description": "claude.ai 대화를 주제별로 자동 분류하고 사이드바에서 네비게이션",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://api.openai.com/*",
    "https://api.anthropic.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": [
        "shared/constants.js",
        "shared/storage.js",
        "content/extractor.js",
        "content/classifier.js",
        "content/sidebar.js",
        "content/navigator.js",
        "content/observer.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
